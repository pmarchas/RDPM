{
  "name": "rdpm",
  "version": "1.0.3",
  "description": "Gestor de conexiones RDP, VNC y SSH",
  "main": "electron/main.js",
  "scripts": {
    "dev":         "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build":       "vite build",
    "build:win":   "vite build && electron-builder --win",
    "build:mac":   "vite build && electron-builder --mac",
    "build:linux": "vite build && electron-builder --linux",
    "build:all":   "vite build && electron-builder --win --mac --linux",
    "preview":     "vite preview"
  },
  "dependencies": {
    "electron-updater": "^6.1.8",
    "qrcode": "^1.5.4",
    "uuid":   "^9.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently":    "^8.2.2",
    "cross-env":       "^7.0.3",
    "electron":        "^28.2.0",
    "electron-builder":"^24.9.1",
    "react":           "^18.2.0",
    "react-dom":       "^18.2.0",
    "sharp":           "^0.34.5",
    "vite":            "^5.1.4",
    "wait-on":         "^7.2.0"
  },
  "build": {
    "appId":       "com.rdpm.app",
    "productName": "RDPM",
    "copyright":   "© 2025 pmarchas",

    "directories": { "output": "dist-app" },
    "asar": true,
    "asarUnpack": ["node_modules/qrcode/**"],

    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/qrcode/**",
      "node_modules/uuid/**",
      "node_modules/electron-updater/**"
    ],

    "extraResources": [
      { "from": "assets/icon.png", "to": "icon.png" },
      { "from": "assets/icon.ico", "to": "icon.ico" }
    ],

    "publish": {
      "provider": "github",
      "owner": "pmarchas",
      "repo": "RDPM"
    },

    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64", "ia32"] }
      ],
      "icon": "assets/icon.ico",
      "legalTrademarks": "RDPM © 2025 pmarchas"
    },

    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon":             "assets/icon.icns",
      "category":         "public.app-category.utilities",
      "hardenedRuntime":  false,
      "gatekeeperAssess": false,
      "darkModeSupport":  true
    },

    "linux": {
      "target": [
        { "target": "deb", "arch": ["x64"] }
      ],
      "icon":     "assets/icon.png",
      "category": "Network",
      "desktop": {
        "Name":       "RDPM",
        "Comment":    "Gestor de conexiones RDP, VNC y SSH",
        "Categories": "Network;RemoteAccess;System;"
      }
    },

    "nsis": {
      "oneClick":                          false,
      "perMachine":                        false,
      "allowElevation":                    true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut":             true,
      "createStartMenuShortcut":           true,
      "shortcutName":                      "RDPM",
      "license":                           "build/license.txt",
      "installerIcon":                     "assets/icon.ico",
      "uninstallerIcon":                   "assets/icon.ico",
      "installerHeaderIcon":               "assets/icon.ico",
      "deleteAppDataOnUninstall":          false,
      "displayLanguageSelector":           false,
      "language":                          "3082"
    },

    "dmg": {
      "title":        "RDPM ${version}",
      "iconSize":     100,
      "iconTextSize": 13,
      "window":  { "width": 540, "height": 380 },
      "contents": [
        { "x": 140, "y": 230, "type": "file"  },
        { "x": 400, "y": 230, "type": "link", "path": "/Applications" }
      ]
    },

    "deb": {
      "priority":    "optional",
      "compression": "xz",
      "depends":     ["libnotify4", "libxtst6", "libnss3"]
    },

    "appImage": {
      "license": null
    }
  }
}
